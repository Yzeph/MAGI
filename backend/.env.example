# =============================================================================
# MAGI — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并按需修改：
#   cp .env.example .env
#
# 文件优先级: .env → .env.local → .secrets → 系统环境变量
#
# 模型名 / API 地址的默认值在 lib/model.js 中维护。
# 如需覆盖，在此文件中设置对应变量即可。
# API 密钥请放在 .secrets 中（已加入 .gitignore）。
# =============================================================================

# ------- 服务器 -------
PORT=3000
NODE_ENV=development

# ------- AI 提供商 -------
# 选项: anthropic | openai | siliconflow | deepseek | openai-compatible
AI_PROVIDER=deepseek

# ------- AI 模型名 (全局覆盖) -------
# 设置此项会覆盖所有 provider 的默认模型名
# AI_MODEL=deepseek-chat

# ------- 模型名 / API 地址 / 超时 (覆盖各 provider 默认值) -------
# 不设置则使用 lib/model.js 中的默认值。
# 优先级: AI_MODEL > 专用模型变量 > 默认值

# Anthropic
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=

# OpenAI
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# SiliconFlow
# SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# DeepSeek
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TIMEOUT=60000

# 本地 OpenAI 兼容服务 (Ollama, vLLM, etc.)
# OPENAI_COMPAT_MODEL=qwen2.5:72b
# OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# OPENAI_COMPAT_TIMEOUT=60000

# ------- 各人格独立配置 (可选) -------
# 设置 {NAME}_API_KEY 后，该人格使用独立 provider（含地址/模型/密钥）
# 不设置则复用全局 AI_PROVIDER 配置
# BALTHASAR
# BALTHASAR_API_KEY=
# BALTHASAR_PROVIDER=
# BALTHASAR_BASE_URL=
# BALTHASAR_MODEL=
# CASPER
# CASPER_API_KEY=
# CASPER_PROVIDER=
# CASPER_BASE_URL=
# CASPER_MODEL=
# MELCHIOR
# MELCHIOR_API_KEY=
# MELCHIOR_PROVIDER=
# MELCHIOR_BASE_URL=
# MELCHIOR_MODEL=

# ------- AI 通用参数 -------
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7
AI_ENABLE_THINKING=true

# ------- 辩论引擎 -------
CONSENSUS_THRESHOLD=67

# ------- 数据库 -------
DB_PATH=./magi.db
