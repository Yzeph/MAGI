# ==========================================
# MAGI 超级计算机系统 - 环境变量配置
# ==========================================
#
# 重要：这个文件是示例模板。
# 不要将真实的API密钥提交到Git！
#
# 复制此文件为 .env 并填入你的实际配置
# cp .env.example .env
#
# ==========================================

# ========== 服务器配置 ==========
PORT=3000
WS_PORT=3001
NODE_ENV=development

# ========== AI模型提供商选择 ==========
# 选项: 'anthropic', 'openai', 'siliconflow', 'openai-compatible'
# 推荐: siliconflow (国内推荐，成本低廉)
AI_PROVIDER=siliconflow

# ========== Anthropic Claude 配置 ==========
# 从 https://console.anthropic.com 获取API密钥
# 不要将真实的密钥放在这个示例文件中
# 改用 .secrets 文件或环境变量
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# ========== OpenAI 配置 ==========
# 从 https://platform.openai.com/api-keys 获取API密钥
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# ========== SiliconFlow 配置 (推荐用于国内) ==========
# 从 https://cloud.siliconflow.cn 获取API密钥
# 支持多个开源大模型: Qwen, Llama, Mistral 等
# 成本低廉，性能优秀，国内访问快速
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
SILICONFLOW_TIMEOUT=60000

# ========== OpenAI 兼容格式 ==========
# 用于本地模型 (LM Studio, Ollama, LocalAI 等)
OPENAI_COMPAT_API_KEY=not-needed
OPENAI_COMPAT_MODEL=local-model
OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
OPENAI_COMPAT_TIMEOUT=60000

# ========== AI 通用配置 ==========
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_TOP_P=1.0
AI_ENABLE_THINKING=true

# ========== 数据库配置 ==========
DB_PATH=./magi.db

# ==========================================
# 安全提示
# ==========================================
#
# ✅ DO:
# - 使用 .secrets 文件存储真实密钥（仅本地开发）
# - 使用环境变量注入密钥（生产环境）
# - 使用密钥管理服务（AWS Secrets Manager, Vault等）
# - 定期轮转API密钥
#
# ❌ DON'T:
# - 将真实的API密钥提交到Git
# - 在代码中硬编码密钥
# - 将.env文件添加到Git
# - 与他人共享API密钥
#
# ==========================================

